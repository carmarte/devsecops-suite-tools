<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reporte de Seguridad Semgrep</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- DataTables + Buttons + Responsive -->
  <link href="https://cdn.datatables.net/v/bs5/dt-1.13.4/b-2.3.6/b-html5-2.3.6/r-2.5.0/datatables.min.css" rel="stylesheet" />

  <!-- jQuery + Bootstrap + DataTables -->
  <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.0/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-1.13.4/b-2.3.6/r-2.5.0/datatables.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

  <style>
    :root {
      --bg-light: #ffffff;
      --text-light: #222;
      --bg-dark: #1e1e1e;
      --text-dark: #e0e0e0;
    }
    body {
      font-family: Arial, sans-serif;
      background-color: var(--bg-light);
      color: var(--text-light);
      padding: 20px;
    }
    body.dark-mode {
      background-color: var(--bg-dark);
      color: var(--text-dark);
    }
    .toggle-btn {
      float: right;
      margin-bottom: 10px;
      padding: 6px 12px;
      background-color: #007bff;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }
    h1 { margin-top: 1rem; }
    td.severity-WARNING { background-color: #ffe033; color: #000; font-weight: bold; }
    td.severity-INFO { background-color:rgb(107, 76, 245); color: #fff; font-weight: bold; }
    td.severity-HIGH { background-color: #f0ad4e; color: #000; font-weight: bold; }
    td.severity-CRITICAL { background-color: #d9534f; color: #fff; font-weight: bold; }
    td.severity-MEDIUM { background-color: #5bc0de; color: #000; font-weight: bold; }
    td.severity-LOW { background-color: #5cb85c; color: #fff; font-weight: bold; }
    td.severity-UNKNOWN { background-color: #777; color: #fff; font-weight: bold; }
    code {
      background-color: #eee;
      padding: 2px 4px;
      border-radius: 3px;
    }
    footer {
      text-align: center;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #eee;
      color: #777;
      font-size: 0.9em;
    }
  </style>
</head>
<body>
<div class="container-fluid">
  <button class="toggle-btn" onclick="document.body.classList.toggle('dark-mode')">🌗 Cambiar Modo</button>
  <h1>Reporte de Seguridad Semgrep</h1>

  <div class="alert alert-secondary">
    <p><strong>Fecha del Reporte:</strong> {{ (datasource "context").date }}</p>
    <p><strong>Total de Hallazgos:</strong> {{ len (datasource "data").results }}</p>
  </div>

  {{ if (datasource "data").results }}
  <div class="table-responsive">
    <table id="semgrepTable" class="table table-striped table-bordered nowrap" style="width:100%">
      <thead class="table-primary">
        <tr>
          <th>Regla</th>
          <th>Severidad</th>
          <th>Mensaje</th>
          <th>Archivo</th>
          <th>Línea</th>
          <th>CWE</th>
          <th>OWASP</th>
          <th>Referencias</th>
        </tr>
      </thead>
      <tbody>
        {{ range (datasource "data").results }}
        <tr>
          <td>{{ .check_id }}</td>
          <td class="severity-{{ .extra.severity }}">{{ .extra.severity }}</td>
          <td>{{ .extra.message }}</td>
          <td><code>{{ .path }}</code></td>
          <td>{{ .start.line }}</td>
          <td>
            {{ if index .extra "metadata" }}
              {{ if index (index .extra "metadata") "cwe" }}
                {{ range $i, $cwe := index (index .extra "metadata") "cwe" }}{{ if $i }}, {{ end }}{{ $cwe }}{{ end }}
              {{ end }}
            {{ end }}
          </td>
          <td>
            {{ if index .extra "metadata" }}
              {{ $owasp := index (index .extra "metadata") "owasp" }}
              {{ if $owasp }}
                {{ if eq (printf "%T" $owasp) "string" }}
                  {{ $owasp }}
                {{ else }}
                  {{ range $i, $o := $owasp }}{{ if $i }}, {{ end }}{{ $o }}{{ end }}
                {{ end }}
              {{ else }}N/A{{ end }}
            {{ end }}
          </td>
          <td>
            {{ if index .extra "metadata" }}
              {{ if index (index .extra "metadata") "references" }}
                {{ range index (index .extra "metadata") "references" }}
                  <a href="{{ . }}" target="_blank">🔗</a>&nbsp;
                {{ end }}
              {{ end }}
            {{ end }}
          </td>
        </tr>
        {{ end }}
      </tbody>
    </table>
  </div>
  {{ else }}
    <p>No se encontraron hallazgos de seguridad en este escaneo.</p>
  {{ end }}

  <footer class="mt-5">Generado por Semgrep + Gomplate</footer>
</div>

<script>
  $(document).ready(function () {
    $('#semgrepTable').DataTable({
      dom: 'Bfrtip',
      buttons: ['copyHtml5', 'excelHtml5', 'pdfHtml5'],
      responsive: true,
      scrollX: true
    });
  });
</script>
</body>
</html>
